@model Entities.ViewModels.Teachers.TeacherHomeViewModel

@{
    Layout = "_AppShell";
    ViewData["Title"] = "Моите предмети";
    ViewData["ActiveNav"] = "MySubjects";
    ViewData["ShellUserName"] = Model.TeacherName;
    ViewData["ShellUserMeta"] = "Учител";
    ViewData["ShellUserInitials"] = Model.TeacherInitials;
}

@section Styles {
<style>
    .nb-teacher-subjects-page {
        min-width: 0;
        padding: 28px 34px 44px;
    }

    .nb-subjects-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 20px;
    }

    .nb-subjects-header h2 {
        margin: 0;
        color: #20232a;
        font-size: 22px;
        font-weight: 950;
    }

    .nb-subjects-header p {
        margin: 6px 0 0;
        color: #8f887f;
        font-size: 13px;
        font-weight: 800;
    }

    .nb-subject-card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 14px;
    }

    .nb-subject-card {
        min-height: 154px;
        display: grid;
        align-content: space-between;
        gap: 20px;
        padding: 18px;
        border: 1px solid #eee7df;
        border-radius: 8px;
        background: #ffffff;
        color: inherit;
        text-decoration: none;
        box-shadow: 0 10px 22px rgba(42, 35, 29, 0.05);
        transition: border-color 0.16s ease, box-shadow 0.16s ease, transform 0.16s ease;
    }

    .nb-subject-card:hover,
    .nb-subject-card:focus-visible {
        border-color: #f97316;
        box-shadow: 0 14px 30px rgba(42, 35, 29, 0.09);
        outline: none;
        transform: translateY(-1px);
    }

    .nb-subject-card h3 {
        margin: 0;
        color: #1f232b;
        font-size: 20px;
        font-weight: 950;
        line-height: 1.15;
    }

    .nb-subject-card-class {
        width: fit-content;
        min-height: 24px;
        display: inline-flex;
        align-items: center;
        margin-bottom: 10px;
        padding: 3px 9px;
        border-radius: 999px;
        background: #fff0dc;
        color: #d95f0b;
        font-size: 11px;
        font-weight: 950;
    }

    .nb-subject-card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        color: #8b837a;
        font-size: 12px;
        font-weight: 850;
    }

    .nb-subject-card-meta i {
        color: #f97316;
    }

    .nb-empty-subject-picker {
        min-height: 180px;
        display: grid;
        place-items: center;
        border: 1px solid #eee7df;
        border-radius: 8px;
        background: #ffffff;
        color: #8f887f;
        font-size: 14px;
        font-weight: 850;
        text-align: center;
    }

    @@media (max-width: 640px) {
        .nb-teacher-subjects-page {
            padding: 18px;
        }

        .nb-subjects-header {
            display: grid;
        }
    }
</style>
}

<section class="nb-teacher-subjects-page" aria-label="Моите предмети">
    <header class="nb-subjects-header">
        <div>
            <h2>Изберете предмет</h2>
            <p>Предмети и класове, в които преподавате.</p>
        </div>
    </header>

    @if (Model.TeachingSubjects.Count == 0)
    {
        <div class="nb-empty-subject-picker">Няма назначени предмети.</div>
    }
    else
    {
        <div class="nb-subject-card-grid">
            @foreach (var subject in Model.TeachingSubjects)
            {
                <a class="nb-subject-card"
                   asp-controller="Teacher"
                   asp-action="MyClass"
                   asp-route-classId="@subject.ClassId"
                   asp-route-classSubjectId="@subject.ClassSubjectId">
                    <span>
                        <span class="nb-subject-card-class">Клас @subject.ClassName</span>
                        <h3>@subject.SubjectName</h3>
                    </span>
                    <span class="nb-subject-card-meta">
                        <span>@subject.StudentCount ученици</span>
                        <i class="bi bi-arrow-right" aria-hidden="true"></i>
                    </span>
                </a>
            }
        </div>
    }
</section>

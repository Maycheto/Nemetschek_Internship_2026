@model Web.ViewModels.ParentHomeViewModel
@{
    Layout = "_ParentLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/parent/home.css" />
}

<div class="dashboard-grid">

    <!-- Summary Card -->
    <div class="dashboard-card">
        <h3>Summary</h3>

        <p><strong>Feedbacks:</strong> @Model.Summary?.FeedbacksCount</p>
        <p><strong>Absences:</strong> @Model.Summary?.AbsencesCount</p>
    </div>

    <!-- Subject Averages -->
    <div class="dashboard-card">
        <h3>Subject Averages</h3>

        @foreach (var avg in Model.SubjectAverages)
        {
            <div style="margin-bottom: 12px;">
                <strong>@avg.SubjectName</strong>
                <div class="progress-bar">
                    <div class="progress-bar-fill" style="--progress:@avg.Average%"></div>
                </div>
            </div>
        }
    </div>

    <!-- Recent Activity -->
    <div class="dashboard-card">
        <h3>Recent Activity</h3>

        @foreach (var act in Model.RecentActivity)
        {
            <p>
                <strong>@act.Date.ToShortDateString()</strong> — @act.Description
            </p>
        }
    </div>

</div>

<!-- Today Schedule -->
<div class="dashboard-card" style="margin-top: 24px;">
    <h3>Today's Schedule</h3>

    @foreach (var entry in Model.TodaySchedule)
    {
        <p>
            <strong>Lesson @entry.LessonNumber:</strong> @entry.SubjectName
        </p>
    }
</div>

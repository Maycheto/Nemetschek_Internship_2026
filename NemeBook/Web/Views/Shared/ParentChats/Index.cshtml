@model Web.ViewModels.ParentChatsViewModel
@{
    Layout = "_ParentLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/parent/chats.css" />
}

<div class="chats-container">

    <!-- Teacher List -->
    <div class="teacher-list">
        <h3>Teachers</h3>

        @foreach (var subject in Model.Subjects)
        {
            <div class="teacher-item @(subject == Model.SelectedSubject ? "active" : "")">
                <a asp-action="Index"
                   asp-route-parentUserId="@Model.ParentUserId"
                   asp-route-studentId="@Model.StudentId"
                   asp-route-subject="@subject">
                    @subject
                </a>
            </div>
        }
    </div>

    <!-- Chat Window -->
    <div class="chat-window">
        <div class="chat-messages">
            @foreach (var msg in Model.Messages)
            {
                <div class="chat-bubble @(msg.IsFromParent ? "parent" : "teacher")">
                    <strong>@msg.SenderName</strong><br />
                    @msg.Text
                    <div style="font-size: 11px; opacity: 0.6;">
                        @msg.SentAt.ToShortTimeString()
                    </div>
                </div>
            }
        </div>

        <form asp-action="Send" method="post" class="chat-input">
            <input type="hidden" name="parentUserId" value="@Model.ParentUserId" />
            <input type="hidden" name="chatId" value="@Model.ChatId" />
            <input type="hidden" name="subject" value="@Model.SelectedSubject" />
            <input type="hidden" name="studentId" value="@Model.StudentId" />

            <input type="text" name="message" placeholder="Type a message..." required />
            <button type="submit">Send</button>
        </form>
    </div>

</div>

@model Web.ViewModels.ParentScheduleViewModel
@{
    Layout = "_ParentLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/parent/schedule.css" />
}

<div class="schedule-container">

    <!-- Day Buttons -->
    <div class="schedule-days">
        @foreach (var day in Model.Days)
        {
            <a asp-action="Index"
               asp-route-studentId="@Model.SelectedStudentId"
               asp-route-day="@day.Key">
                <button class="@(Model.SelectedDay == day.Key ? "active" : "")">
                    @day.Value
                </button>
            </a>
        }
    </div>

    <!-- Schedule Table -->
    <table class="schedule-table">
        <thead>
            <tr>
                <th>Time</th>
                <th>Subject</th>
                <th>Room</th>
                <th>Teacher</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var row in Model.Entries)
            {
                <tr>
                    <td>@row.TimeRange</td>
                    <td>@row.SubjectName</td>
                    <td>@row.Room</td>
                    <td>@row.TeacherName</td>
                </tr>
            }
        </tbody>
    </table>

</div>

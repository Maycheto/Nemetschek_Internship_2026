@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <title>NemoBook Родителски портал</title>

    <!-- Глобален Layout CSS -->
    <link rel="stylesheet" href="~/css/_layout.css" />

    <!-- Layout CSS за родителския портал -->
    <link rel="stylesheet" href="~/css/parent/layout.css" />

    <!-- Sidebar CSS -->
    <link rel="stylesheet" href="~/css/parent/sidebar.css" />

    <!-- CSS за конкретна страница -->
    @RenderSection("Styles", required: false)
</head>

<body>
    <div class="nb-parent-layout">

        <!-- Sidebar -->
        @await Html.PartialAsync("_ParentSidebar")

        <!-- Основно съдържание -->
        <main class="nb-parent-content">
            @RenderBody()
        </main>

    </div>
</body>
</html>


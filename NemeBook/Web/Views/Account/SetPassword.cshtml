@model Entities.ViewModels.Auth.SetPasswordViewModel

@{
    ViewData["Title"] = "Създаване на парола";
}

<div class="nb-form-shell">
    <section class="nb-form-card nb-form-card-password" aria-labelledby="set-password-title">
        <div class="nb-auth-brand">
            <div class="nb-auth-logo">N</div>
            <div class="nb-auth-name"><span>Neme</span>Book</div>
        </div>

        <h1 id="set-password-title">Създайте нова парола</h1>
        <p class="nb-form-subtitle">Изберете силна парола, с която ще влизате в профила си.</p>

        <form asp-action="SetPassword" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="nb-form-summary"></div>
            <input asp-for="Token" type="hidden" />

            <div class="nb-form-field">
                <label asp-for="Password" class="nb-form-label">Нова парола</label>
                <div class="nb-input-shell">
                    <i class="bi bi-lock-fill" aria-hidden="true"></i>
                    <input asp-for="Password" class="nb-form-input" autocomplete="new-password" />
                </div>
                <span asp-validation-for="Password" class="nb-validation"></span>
            </div>

            <div class="nb-form-field">
                <label asp-for="ConfirmPassword" class="nb-form-label">Повторете паролата</label>
                <div class="nb-input-shell">
                    <i class="bi bi-lock-fill" aria-hidden="true"></i>
                    <input asp-for="ConfirmPassword" class="nb-form-input" autocomplete="new-password" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="nb-validation"></span>
            </div>

            <button type="submit" class="nb-primary-action">Потвърди паролата</button>

            <p class="nb-form-note">
                <i class="bi bi-check-circle" aria-hidden="true"></i>
                Паролата трябва да бъде поне 8 символа.
            </p>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
